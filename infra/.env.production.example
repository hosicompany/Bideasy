# BidEasy Production Environment Variables
# Copy to .env.production and fill in real values
# NEVER commit .env.production to git

# === Security (REQUIRED — generate unique values) ===
JWT_SECRET_KEY=          # openssl rand -base64 48
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Database ===
DATABASE_MODE=postgresql
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=bideasy
POSTGRES_PASSWORD=       # Strong password here
POSTGRES_DB=bideasy_db

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379

# === External APIs (REQUIRED) ===
OPENAI_API_KEY=          # sk-...
PUBLIC_DATA_KEY=          # data.go.kr API key

# === OAuth — Kakao ===
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_NATIVE_APP_KEY=

# === OAuth — Naver ===
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# === Toss Payments ===
TOSS_CLIENT_KEY=         # live_ key (not test_)
TOSS_SECRET_KEY=         # live_ secret
TOSS_WEBHOOK_SECRET=

# === Frontend URL ===
FRONTEND_URL=https://bideasy.kr

# === CORS ===
BACKEND_CORS_ORIGINS=["https://bideasy.kr","https://www.bideasy.kr"]

# === ML Models ===
ML_MODELS_PATH=./models
HISTORICAL_DB_PATH=./data/historical/bid_results_5years.db

# === App ===
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
AI_ANALYSIS_FREE_LIMIT=1

# === Firebase (FCM Push Notifications) ===
FIREBASE_CREDENTIALS_JSON=./firebase-service-account.json

# === Sentry ===
SENTRY_DSN=               # https://xxx@oXXX.ingest.sentry.io/YYY
