# BidEasy Environment Configuration
# Copy this file to .env and fill in your values

# === REQUIRED ===
OPENAI_API_KEY=your-openai-api-key-here
PUBLIC_DATA_KEY=your-public-data-portal-key-here

# === Security ===
JWT_SECRET_KEY=generate-a-random-64-char-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Database ===
# "sqlite" for local dev, "postgresql" for production
DATABASE_MODE=sqlite
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bideasy
POSTGRES_PASSWORD=bideasy_pass
POSTGRES_DB=bideasy_db

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === CORS ===
# JSON array of allowed origins
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://127.0.0.1:8080"]

# === ML Models ===
ML_MODELS_PATH=./models
HISTORICAL_DB_PATH=./data/historical/bid_results_5years.db

# === App ===
APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=text
AI_ANALYSIS_FREE_LIMIT=5
